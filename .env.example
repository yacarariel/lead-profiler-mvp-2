# Copiá este archivo como .env y completá los valores

# Token secreto para proteger el endpoint de sync
# Generalo con: openssl rand -hex 16
SYNC_TOKEN=cambia-esto-por-un-token-secreto

# URL de tu app en Railway (se completa después del deploy)
# Ejemplo: https://lead-profiler-production.up.railway.app
APP_URL=

# En producción Railway inyecta PORT automáticamente — no lo toques
# PORT=3001
